rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // catch-all: default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // global security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Product specification verification
    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.price is number && data.price >= 0
          && data.stock_qty is number && data.stock_qty >= 0
          && data.image is string && data.image.size() <= 100
          && data.category is string && data.category.size() <= 100
          && data.owner_uid is string && data.owner_uid.size() <= 128;
    }

    // Order validation helper
    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128
          && data.customer_name is string && data.customer_name.size() <= 200
          && data.customer_phone is string && data.customer_phone.size() <= 50
          && data.address is string && data.address.size() <= 1000
          && data.items is list && data.items.size() <= 50
          && data.total_amount is number && data.total_amount >= 0
          && data.status is string && data.status in ['pending', 'confirmed', 'shipped', 'completed', 'cancelled']
          && data.payment_method is string && data.payment_method.size() <= 100
          && data.created_at is string && data.created_at.size() <= 50
          && data.owner_uid is string && data.owner_uid.size() <= 128;
    }

    // Shop settings schema checking
    function isValidShopSettings(data) {
      return data.owner_uid is string && data.owner_uid.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.phone is string && data.phone.size() <= 50
          && data.address is string && data.address.size() <= 500
          && data.kpay_number is string && data.kpay_number.size() <= 100
          && data.kpay_name is string && data.kpay_name.size() <= 200
          && data.slug is string && data.slug.size() <= 100;
    }

    // Products collection rules
    match /products/{productId} {
      allow read: if true; // Customers need to browse products
      allow create: if isSignedIn()
                    && isValidId(productId)
                    && request.resource.data.owner_uid == request.auth.uid
                    && isValidProduct(request.resource.data);
      allow update: if isSignedIn()
                    && request.auth.uid == resource.data.owner_uid
                    && request.resource.data.owner_uid == resource.data.owner_uid
                    && isValidProduct(request.resource.data);
      allow delete: if isSignedIn()
                    && request.auth.uid == resource.data.owner_uid;
    }

    // Orders collection rules
    match /orders/{orderId} {
      allow get: if true; // Anyone can retrieve a single order invoice/voucher details
      allow list: if isSignedIn() && resource.data.owner_uid == request.auth.uid; // Only seller can list orders
      
      // Guest customers can submit orders
      allow create: if isValidId(orderId)
                    && isValidOrder(request.resource.data);
                    
      allow update: if isSignedIn()
                    && request.auth.uid == resource.data.owner_uid
                    && request.resource.data.owner_uid == resource.data.owner_uid
                    && isValidOrder(request.resource.data);
                    
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    // Shop Settings collection rules
    match /shop_settings/{owner_uid} {
      allow read: if true; // Public storefront can view shop identity
      allow write: if isSignedIn()
                   && request.auth.uid == owner_uid
                   && request.resource.data.owner_uid == owner_uid
                   && isValidShopSettings(request.resource.data);
    }
  }
}
